def fetch_data_simulated(symbol="TQQQ"):
    """Datos simulados para probar"""
    print("📡 Usando datos simulados")
    
    np.random.seed(42)
    periods = 100
    dates = pd.date_range(end=datetime.now(), periods=periods, freq='1h')
    
    df = pd.DataFrame(index=dates)
    
    # Simular precio con tendencia + ondas
    t = np.arange(periods)
    trend = 45 + t * 0.05
    waves = 5 * np.sin(t / 10) + 3 * np.cos(t / 5)
    noise = np.random.randn(periods) * 0.5
    
    price = trend + waves + noise
    
    df['Close'] = price
    df['High'] = df['Close'] * (1 + np.abs(np.random.randn(periods) * 0.01))
    df['Low'] = df['Close'] * (1 - np.abs(np.random.randn(periods) * 0.01))
    df['Open'] = df['Close'].shift(1).fillna(df['Close'].iloc[0] * 0.99)
    df['Volume'] = np.random.randint(1000000, 10000000, periods)
    
    print(f"✅ {len(df)} velas simuladas")
    return df

