# 2. VWAP CLÁSICO (INVESTING)
# ============================================
def calculate_vwap_investing(df):
    """VWAP como lo calcula Investing"""
    df = df.copy()
    df['typical'] = (df['High'] + df['Low'] + df['Close']) / 3
    df['pv'] = df['typical'] * df['Volume']
    df['date'] = df.index.date
    df['cum_pv'] = df.groupby('date')['pv'].cumsum()
    df['cum_vol'] = df.groupby('date')['Volume'].cumsum()
    df['VWAP_investing'] = df['cum_pv'] / df['cum_vol']
    return df['VWAP_investing']

# ============================================
# 3. NUESTRA FÓRMULA VWAP ORBITAL
# ============================================
def calculate_vwap_orbital(df, lambda_decay=0.2, alpha_smooth=0.2):
    """
    Nuestra versión mejorada
    
    Parámetros:
    - lambda_decay: qué tan rápido pierden peso las velas antiguas (0.1-0.5)
    - alpha_smooth: suavizado exponencial (0.1-0.5)
    """
    df = df.copy()
    df['typical'] = (df['High'] + df['Low'] + df['Close']) / 3
    
    # Pesos temporales (más peso a velas recientes)
    n = len(df)
    weights = np.exp(-lambda_decay * np.arange(n)[::-1])
    df['time_weight'] = weights / weights.mean()  # normalizar
    
    # Versión 1: Con decaimiento temporal
    df['weighted_pv'] = df['typical'] * df['Volume'] * df['time_weight']
    df['weighted_vol'] = df['Volume'] * df['time_weight']
    
    # Acumular con suavizado exponencial
    vwap_orbital = []
    cum_pv = 0
    cum_vol = 0
    
    for i in range(len(df)):
        # Suavizado exponencial
        cum_pv = alpha_smooth * cum_pv + (1 - alpha_smooth) * df['weighted_pv'].iloc[i]
        cum_vol = alpha_smooth * cum_vol + (1 - alpha_smooth) * df['weighted_vol'].iloc[i]
        
        vwap = cum_pv / cum_vol if cum_vol > 0 else df['typical'].iloc[i]
        vwap_orbital.append(vwap)
    
    return pd.Series(vwap_orbital, index=df.index)

# ============================================
# 4. VERSIÓN ULTRA PEGADA (para pruebas extremas)
# ============================================
def calculate_vwap_ultra(df, reactivity=0.3):
    """
    Versión que sigue al precio como sombra
    reactivity: 0.1 (lento) a 0.5 (muy rápido)
    """
    df = df.copy()
    df['typical'] = (df['High'] + df['Low'] + df['Close']) / 3
    
    vwap = [df['typical'].iloc[0]]
    
    for i in range(1, len(df)):
        # Media móvil ponderada con énfasis en el precio actual
        weight_current = reactivity
        weight_prev = 1 - reactivity
        
        vwap_current = (weight_current * df['typical'].iloc[i] + 
                        weight_prev * vwap[-1])
        vwap.append(vwap_current)
    
    return pd.Series(vwap, index=df.index)

