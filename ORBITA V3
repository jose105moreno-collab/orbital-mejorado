# ============================================
# FUNCIONES DE TELEGRAM
# ============================================
def send_telegram(message):
    if not TELEGRAM_TOKEN or not TELEGRAM_CHAT_ID:
        return False
    try:
        url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
        data = {
            'chat_id': TELEGRAM_CHAT_ID,
            'text': message,
            'parse_mode': 'Markdown'
        }
        response = requests.post(url, data=data, timeout=10)
        return response.status_code == 200
    except:
        return False

# ============================================
# OBTENER DATOS DE ALPACA (STOCKS)
# ============================================
def get_alpaca_data(symbol, start, end, timeframe="1Hour"):
    if not ALPACA_API_KEY or not ALPACA_SECRET_KEY:
        return None
    url = f"https://data.alpaca.markets/v2/stocks/{symbol}/bars"
    headers = {
        'APCA-API-KEY-ID': ALPACA_API_KEY,
        'APCA-API-SECRET-KEY': ALPACA_SECRET_KEY
    }
    params = {
        'timeframe': timeframe,
        'start': start.strftime('%Y-%m-%dT%H:%M:%SZ'),
        'end': end.strftime('%Y-%m-%dT%H:%M:%SZ'),
        'limit': 1000
    }
    try:
        r = requests.get(url, headers=headers, params=params, timeout=10)
        if r.status_code == 200:
            data = r.json()
            bars = data.get('bars', [])
            if bars:
                df = pd.DataFrame(bars)
                df['timestamp'] = pd.to_datetime(df['t'])
                df.set_index('timestamp', inplace=True)
                df.rename(columns={'o':'Open','h':'High','l':'Low','c':'Close','v':'Volume'}, inplace=True)
                return df
    except:
        pass
    return None

# ============================================
# OBTENER DATOS DE COINGECKO (CRYPTO)
# ============================================
def get_coingecko_data(symbol, days=5):
    """Obtiene datos horarios de CoinGecko (gratis, sin API key)"""
    # Mapeo de símbolos a ids de CoinGecko
    coin_map = {
        'BTC-USD': 'bitcoin',
        'ETH-USD': 'ethereum',
        'SOL-USD': 'solana',
        'ADA-USD': 'cardano',
        'DOGE-USD': 'dogecoin',
        'DOT-USD': 'polkadot',
        'LINK-USD': 'chainlink',
        'MATIC-USD': 'matic-network',
        'AVAX-USD': 'avalanche-2',
        'UNI-USD': 'uniswap',
    }
    coin_id = coin_map.get(symbol)
    if not coin_id:
        return None
    
    url = f"https://api.coingecko.com/api/v3/coins/{coin_id}/market_chart"
    params = {
        'vs_currency': 'usd',
        'days': days,
        'interval': 'hourly'  # Coingecko da datos horarios
    }
    try:
        r = requests.get(url, params=params, timeout=15)
        if r.status_code == 200:
            data = r.json()
            prices = data['prices']  # lista de [timestamp, price]
            volumes = data['total_volumes']  # lista de [timestamp, volume]
            
            # Crear DataFrame
            df_prices = pd.DataFrame(prices, columns=['timestamp', 'Close'])
            df_volumes = pd.DataFrame(volumes, columns=['timestamp', 'Volume'])
            df = pd.merge(df_prices, df_volumes, on='timestamp')
            df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')
            df.set_index('timestamp', inplace=True)
            df.sort_index(inplace=True)
            
            # Simular High/Low/Open (Coingecko no los da, aproximamos)
            df['High'] = df['Close'] * (1 + 0.005)  # 0.5% arriba
            df['Low'] = df['Close'] * (1 - 0.005)   # 0.5% abajo
            df['Open'] = df['Close'].shift(1).fillna(df['Close'] * 0.995)
            return df
    except:
        pass
    return None

# ============================================
# OBTENER DATOS DE YFINANCE (FALLBACK)
# ============================================
def get_yfinance_data(symbol, period="2d", interval="1h", max_retries=3):
    for intento in range(max_retries):
        try:
            import yfinance as yf
            session = requests.Session()
            session.headers.update({'User-Agent': 'Mozilla/5.0'})
            ticker = yf.Ticker(symbol, session=session)
            df = ticker.history(period=period, interval=interval)
            if not df.empty:
                return df
            time.sleep(2 ** intento)  # espera exponencial
        except:
            time.sleep(2 ** intento)
    return None

# ============================================
# FUNCIÓN PRINCIPAL PARA OBTENER DATOS (CON REINTENTOS)
# ============================================
def get_market_data(symbol):
    print(f"🔍 Buscando datos para {symbol}...")
    
    # 1. Si es crypto, probar CoinGecko primero
    if '-USD' in symbol:
        df = get_coingecko_data(symbol, days=5)
        if df is not None:
            print(f"✅ {len(df)} velas de CoinGecko")
            return df, 'coingecko'
    
    # 2. Si es stock, probar Alpaca
    elif ALPACA_API_KEY:
        end = datetime.now()
        start = end - timedelta(days=5)
        df = get_alpaca_data(symbol, start, end)
        if df is not None:
            print(f"✅ {len(df)} velas de Alpaca")
            return df, 'alpaca'
    
    # 3. Fallback: yfinance
    print("📡 Intentando yfinance...")
    df = get_yfinance_data(symbol)
    if df is not None:
        print(f"✅ {len(df)} velas de yfinance")
        return df, 'yfinance'
    
    print("❌ No se pudieron obtener datos reales")
    return None, None

# ============================================
# VWAP ORBITAL (FÓRMULA GANADORA)
# ============================================
def vwap_orbital(df, lambda_decay=0.3, alpha_smooth=0.1):
    df = df.copy()
    df['typical'] = (df['High'] + df['Low'] + df['Close']) / 3
    n = len(df)
    weights = np.exp(-lambda_decay * np.arange(n)[::-1])
    df['time_weight'] = weights / weights.mean()
    df['weighted_pv'] = df['typical'] * df['Volume'] * df['time_weight']
    df['weighted_vol'] = df['Volume'] * df['time_weight']
    vwap = []
    cum_pv = df['weighted_pv'].iloc[0]
    cum_vol = df['weighted_vol'].iloc[0]
    vwap.append(cum_pv / cum_vol)
    for i in range(1, len(df)):
        cum_pv = alpha_smooth * cum_pv + (1 - alpha_smooth) * df['weighted_pv'].iloc[i]
        cum_vol = alpha_smooth * cum_vol + (1 - alpha_smooth) * df['weighted_vol'].iloc[i]
        vwap.append(cum_pv / cum_vol)
    return pd.Series(vwap, index=df.index)

