            print(f"📊 {symbol} - {now} (fuente: {fuente})")
            print(f"Precio: ${precio:.2f}")
            print(f"VWAP Orbital: ${vwap:.2f}")
            print(f"Desviación: {desviacion:+.2f}%")
            
            # Lógica de señal de VENTA
            if desviacion > 1.0:
                fuerza = min(5, int(desviacion * 2))
                senal = "SEÑAL DE VENTA"
                emoji = "🔴"
                if senal != ultima_senal or desviacion > 2.0:
                    msg = f"""🔴 *SEÑAL DE VENTA {symbol}*

📊 Precio: ${precio:.2f}
🎯 VWAP: ${vwap:.2f}
📈 Desviación: +{desviacion:.2f}%
💪 Fuerza: {'🔥' * fuerza}

⚠️ Precio sobrevalorado
🎯 Objetivo: VWAP (${vwap:.2f})
🛸 GODZILLA ORBITAL
⏰ {now}"""
                    if TELEGRAM_TOKEN:
                        send_telegram(msg)
                    else:
                        print("\n" + msg)
                    ultima_senal = senal
                print(f"🔴 SEÑAL: {senal} (fuerza {fuerza})")
            else:
                print(f"⚪ SIN SEÑAL (desviación {desviacion:+.2f}%)")
                ultima_senal = ""
            
            print(f"{'='*60}")
            time.sleep(intervalo * 60)
            
        except KeyboardInterrupt:
            print("\n🛑 Monitoreo detenido")
            if TELEGRAM_TOKEN:
                send_telegram("🛑 *GODZILLA ORBITAL* detuvo el monitoreo")
            break
        except Exception as e:
            print(f"❌ Error: {e}")
            time.sleep(60)

