# 4. GENERADOR DE SEÑALES ORBITALES
# =================================================================================

class OrbitalSignalGenerator:
    """Generador de señales basado en física orbital"""
    
    def __init__(self, config: OrbitalConfig = None):
        self.config = config or OrbitalConfig()
        self.vwap_calc = VWAPCalculator(self.config)
        self.energy_calc = OrbitalEnergyCalculator(self.config)
        self.bbands = AdaptiveBollingerBands(self.config)
        
        self.last_signals = {}
        self.signals_history = []
    
    def generate(self, df: pd.DataFrame, symbol: str = "SYMBOL") -> Dict:
        """Genera señal completa para un símbolo"""
        if len(df) < self.config.bb_period + 10:
            return {
                'symbol': symbol,
                'signal': 0,
                'confidence': 0,
                'state': 'INSUFFICIENT_DATA',
                'reason': 'Datos insuficientes'
            }
        
        # 1. Calcular VWAP
        vwap = self.vwap_calc.calculate(df, symbol)
        
        # 2. Calcular energía orbital
        energy = self.energy_calc.calculate(df, vwap, symbol)
        current_energy = energy.iloc[-1] if not energy.empty else 0
        
        # 3. Determinar estado orbital
        state, state_confidence = self.energy_calc.get_state(current_energy)
        
        # 4. Calcular bandas adaptativas
        bands = self.bbands.calculate(df, state)
        
        # 5. Valores actuales
        current_price = df['Close'].iloc[-1]
        current_vwap = vwap.iloc[-1] if not vwap.empty else current_price
        current_bb_upper = bands['upper'].iloc[-1]
        current_bb_lower = bands['lower'].iloc[-1]
        current_bb_middle = bands['middle'].iloc[-1]
        
        # 6. Desviaciones
        vwap_deviation = ((current_price / current_vwap) - 1) * 100
        bb_position = ((current_price - current_bb_lower) / 
                      (current_bb_upper - current_bb_lower)) * 100
        
        # 7. GENERAR SEÑAL
        signal = 0
        confidence = 0
        reason = []
        
        # Breakout superior
        if current_price > current_bb_upper and state == OrbitalState.BREAKOUT:
            signal = -2
            confidence = min(0.9, 0.6 + current_energy * 0.15)
            reason.append(f"BREAKOUT SUPERIOR")
        
        # Breakout inferior
        elif current_price < current_bb_lower and state == OrbitalState.BREAKOUT:
            signal = 2
            confidence = min(0.9, 0.6 + current_energy * 0.15)
            reason.append(f"BREAKOUT INFERIOR")
        
        # Alta energía + bandas
        elif state == OrbitalState.HIGH_ENERGY:
            if current_price >= current_bb_upper * 0.99:
                signal = -1
                confidence = 0.65 + min(current_energy * 0.1, 0.2)
                reason.append(f"ALTA ENERGÍA en superior")
            elif current_price <= current_bb_lower * 1.01:
                signal = 1
                confidence = 0.65 + min(current_energy * 0.1, 0.2)
                reason.append(f"ALTA ENERGÍA en inferior")
        
        # Reversión desde VWAP
        elif state == OrbitalState.LOW_ENERGY and abs(vwap_deviation) < 1.5:
            recent_change = (current_price / df['Close'].iloc[-5] - 1) * 100
            if recent_change < -2:
                signal = 1
                confidence = 0.55
                reason.append(f"REBOTE desde VWAP")
            elif recent_change > 2:
                signal = -1
                confidence = 0.55
                reason.append(f"RECHAZO en VWAP")
        
        result = {
            'symbol': symbol,
            'timestamp': df.index[-1] if len(df) > 0 else None,
            'signal': signal,
            'signal_type': 'STRONG_BUY' if signal == 2 else 'BUY' if signal == 1 else
                          'STRONG_SELL' if signal == -2 else 'SELL' if signal == -1 else 'HOLD',
            'confidence': round(confidence, 3),
            'state': state.value,
            'energy': round(current_energy, 3),
            'price': round(current_price, 2),
            'vwap': round(current_vwap, 2),
            'vwap_deviation': round(vwap_deviation, 2),
            'bb_upper': round(current_bb_upper, 2),
            'bb_lower': round(current_bb_lower, 2),
            'reason': ' | '.join(reason) if reason else 'Sin señal'
        }
        
        self.last_signals[symbol] = result
        self.signals_history.append(result)
        
        return result


