class OrbitalState(Enum):
    """Estados orbitales del precio"""
    LOW_ENERGY = "low_energy"      # Órbita estable (rango)
    HIGH_ENERGY = "high_energy"     # Órbita elíptica (tendencia)
    BREAKOUT = "breakout"           # Escape orbital (explosivo)
    DECAY = "decay"                 # Decaimiento orbital (reversión)


@dataclass
class OrbitalConfig:
    """Configuración del modelo orbital - VERSIÓN OPTIMIZADA"""
    # Bollinger Bands
    bb_period: int = 20
    bb_std_low: float = 1.2      # K para baja energía (más estrecho)
    bb_std_medium: float = 1.8    # K para energía media
    bb_std_high: float = 2.2      # K para alta energía (más amplio)
    
    # VWAP
    vwap_anchor: str = 'daily'    # 'daily' o 'rolling'
    vwap_rolling_period: int = 20
    
    # Energía orbital (thresholds más sensibles)
    energy_window: int = 14
    energy_threshold_low: float = 0.4    # Baja energía
    energy_threshold_high: float = 0.9   # Alta energía
    energy_breakout: float = 1.5         # Breakout
    
    # Señales
    min_confidence: float = 0.55
    cooldown_hours: int = 3


# =================================================================================
# 1. CALCULADOR DE VWAP (PEGADO AL PRECIO)
# =================================================================================

class VWAPCalculator:
    """
    Calcula VWAP que sigue PEGADO al precio
    VWAP = Σ(Precio_Típico * Volumen) / Σ(Volumen)
    El precio típico = (High + Low + Close) / 3
    """
    
    def __init__(self, config: OrbitalConfig):
        self.config = config
        self.last_vwaps = {}
    
    def calculate(self, df: pd.DataFrame, symbol: str = None) -> pd.Series:
        """
        Calcula VWAP que sigue la acción del precio
        
        Args:
            df: DataFrame con OHLCV (ordenado cronológicamente)
            symbol: Identificador para caché
        
        Returns:
            Serie con VWAP (mismo índice que df)
        """
        df = df.copy()
        
        # Asegurar orden cronológico
        df = df.sort_index()
        
        # Calcular precio típico (representativo de la vela)
        df['typical'] = (df['High'] + df['Low'] + df['Close']) / 3
        
        # Producto precio típico * volumen
        df['pv'] = df['typical'] * df['Volume']
        
        if self.config.vwap_anchor == 'daily':
            # VWAP DIARIO (reinicia cada día) - ESTÁNDAR EN MERCADOS
            df['date'] = df.index.date
            
            # Calcular acumulados POR DÍA (esto es clave)
            df['cum_pv'] = df.groupby('date')['pv'].cumsum()
            df['cum_vol'] = df.groupby('date')['Volume'].cumsum()
            
        else:  # rolling
            # VWAP de ventana móvil (menos común)
            df['cum_pv'] = df['pv'].rolling(self.config.vwap_rolling_period, min_periods=1).sum()
            df['cum_vol'] = df['Volume'].rolling(self.config.vwap_rolling_period, min_periods=1).sum()
        
        # VWAP = acumulado precio*volumen / acumulado volumen
        # Evitar división por cero
        df['vwap'] = df['cum_pv'] / df['cum_vol'].clip(lower=0.01)
        
        # Limpiar columnas auxiliares
        vwap_series = df['vwap'].copy()
        
        # Guardar último valor para caché
        if symbol and not vwap_series.empty:
            self.last_vwaps[symbol] = vwap_series.iloc[-1]
        
        return vwap_series
    
    def get_deviation(self, price: float, symbol: str = None) -> float:
        """
        Calcula desviación porcentual del VWAP
        Devuelve % positivo si precio > VWAP, negativo si precio < VWAP
        """
        last_vwap = self.last_vwaps.get(symbol, 0)
        if last_vwap and last_vwap > 0:
            return ((price / last_vwap) - 1) * 100
        return 0.0


# =================================================================================
# 2. CALCULADOR DE ENERGÍA ORBITAL (AHORA SIEMPRE POSITIVA)
# =================================================================================

class OrbitalEnergyCalculator:
    """
    Calcula la energía orbital del precio basado en física:
    E_t = |P - VWAP| / ATR * (1 + RSI/100) * (1 + Volume_Ratio)
    
    AHORA CON ENERGÍA SIEMPRE POSITIVA
    """
    
    def __init__(self, config: OrbitalConfig):
        self.config = config
        self.energy_history = {}
    
    def calculate_atr(self, df: pd.DataFrame, period: int = 14) -> pd.Series:
        """Average True Range - medida de volatilidad"""
        high_low = df['High'] - df['Low']
        high_close = abs(df['High'] - df['Close'].shift())
        low_close = abs(df['Low'] - df['Close'].shift())
        
        tr = pd.concat([high_low, high_close, low_close], axis=1).max(axis=1)
        atr = tr.rolling(period).mean()
        
        return atr
    
    def calculate_rsi(self, prices: pd.Series, period: int = 14) -> pd.Series:
        """RSI normalizado (0-100)"""
        delta = prices.diff()
        gain = delta.where(delta > 0, 0).rolling(period).mean()
        loss = (-delta.where(delta < 0, 0)).rolling(period).mean()
        
        rs = gain / loss
        rsi = 100 - (100 / (1 + rs))
        
        return rsi.fillna(50)
    
    def calculate(self, df: pd.DataFrame, vwap: pd.Series, symbol: str = None) -> pd.Series:
        """
        Calcula la energía orbital para cada punto
        AHORA CON ENERGÍA SIEMPRE POSITIVA
        """
        # Distancia al centro gravitacional (normalizada)
        distance_to_vwap = abs(df['Close'] - vwap) / vwap.clip(lower=0.01)
        
        # Volatilidad (ATR normalizado por precio)
        atr = self.calculate_atr(df)
        atr_normalized = atr / df['Close'].clip(lower=0.01)
        
        # RSI (momentum)
        rsi = self.calculate_rsi(df['Close'])
        rsi_factor = 1 + (rsi / 100)  # 1-2
        
        # Volumen (masa)
        volume_ma = df['Volume'].rolling(20).mean()
        volume_ratio = df['Volume'] / volume_ma.clip(lower=0.01)
        volume_factor = 1 + np.log(volume_ratio.clip(lower=0.1, upper=10))
        
        # Energía orbital
        denominator = atr_normalized.clip(lower=0.001)
        energy = (distance_to_vwap / denominator) * rsi_factor * volume_factor
        
        # 👇 CLAVE: ENERGÍA SIEMPRE POSITIVA
        energy = energy.abs()
        
        # Guardar historial
        if symbol and not energy.empty:
            if symbol not in self.energy_history:
                self.energy_history[symbol] = []
            self.energy_history[symbol].append(energy.iloc[-1])
            self.energy_history[symbol] = self.energy_history[symbol][-100:]
        
        return energy
    
    def get_state(self, energy: float) -> Tuple[OrbitalState, float]:
        """
        Clasifica el estado orbital según la energía
        """
        if energy >= self.config.energy_breakout:
            return OrbitalState.BREAKOUT, 1.0
        elif energy >= self.config.energy_threshold_high:
            return OrbitalState.HIGH_ENERGY, 0.8
        elif energy >= self.config.energy_threshold_low:
            return OrbitalState.LOW_ENERGY, 0.5
        else:
            return OrbitalState.DECAY, 0.3


# =================================================================================
# 3. BANDAS DE BOLLINGER ADAPTATIVAS
# =================================================================================

class AdaptiveBollingerBands:
    """Bollinger Bands que se adaptan al estado orbital"""
    
    def __init__(self, config: OrbitalConfig):
        self.config = config
    
    def calculate(self, df: pd.DataFrame, energy_state: OrbitalState) -> Dict:
        """Calcula bandas adaptativas con K variable"""
        log_prices = np.log(df['Close'].clip(lower=0.01))
        
        log_ma = log_prices.rolling(self.config.bb_period).mean()
        log_std = log_prices.rolling(self.config.bb_period).std()
        
        # Seleccionar K según estado
        if energy_state == OrbitalState.LOW_ENERGY:
            k = self.config.bb_std_low
        elif energy_state == OrbitalState.HIGH_ENERGY:
            k = self.config.bb_std_medium
        elif energy_state == OrbitalState.BREAKOUT:
            k = self.config.bb_std_high * 1.2
        else:  # DECAY
            k = self.config.bb_std_low * 0.8
        
        # Convertir a escala lineal
        middle = np.exp(log_ma)
        upper = np.exp(log_ma + k * log_std)
        lower = np.exp(log_ma - k * log_std)
        
        return {
            'middle': middle,
            'upper': upper,
            'lower': lower,
            'k_used': k,
            'band_width': ((upper - lower) / middle) * 100
        }


