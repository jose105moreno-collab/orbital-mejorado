def backtest_orbital_model(symbol: str, days: int = 30):
    """
    Backtesting rápido del modelo orbital
    """
    print(f"\n📊 BACKTESTING: {symbol} - {days} días")
    print("="*60)
    
    # Obtener datos históricos
    df = fetch_market_data(symbol, period=f"{days}d", interval="1h")
    if df is None or df.empty:
        print("❌ No hay datos para backtest")
        return
    
    # Inicializar modelo
    config = OrbitalConfig()
    generator = OrbitalSignalGenerator(config)
    
    # Calcular VWAP y energía
    df['VWAP'] = generator.vwap_calc.calculate(df, symbol)
    df['Energy'] = generator.energy_calc.calculate(df, df['VWAP'], symbol)
    
    # Generar señales
    trades = []
    capital = 10000
    position = 0
    entry_price = 0
    
    for i in range(config.bb_period, len(df)):
        df_window = df.iloc[:i+1].copy()
        signal = generator.generate(df_window, symbol)
        
        if signal['signal'] != 0:
            current_price = df['Close'].iloc[i]
            
            # Lógica simple de trading
            if signal['signal'] > 0 and position == 0:  # COMPRA
                position = capital / current_price
                entry_price = current_price
                trades.append({
                    'type': 'BUY',
                    'price': current_price,
                    'time': df.index[i],
                    'confidence': signal['confidence']
                })
                print(f"  COMPRA en ${current_price:.2f} ({signal['confidence']:.0%})")
                
            elif signal['signal'] < 0 and position > 0:  # VENTA
                profit = (current_price - entry_price) * position
                trades.append({
                    'type': 'SELL',
                    'price': current_price,
                    'time': df.index[i],
                    'profit': profit,
                    'confidence': signal['confidence']
                })
                print(f"  VENTA en ${current_price:.2f} | Profit: ${profit:.2f}")
                position = 0
    
    # Resultados
    if trades:
        profits = [t.get('profit', 0) for t in trades if 'profit' in t]
        winning_trades = sum(1 for p in profits if p > 0)
        
        print("\n" + "="*60)
        print("📈 RESULTADOS BACKTEST")
        print("="*60)
        print(f"Total trades: {len(trades)}")
        if profits:
            print(f"Trades ganadores: {winning_trades}/{len(profits)} ({winning_trades/len(profits)*100:.1f}%)")
            print(f"Profit total: ${sum(profits):.2f}")
            print(f"Profit promedio: ${np.mean(profits):.2f}")
    
    return trades


