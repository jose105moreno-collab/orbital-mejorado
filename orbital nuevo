def fetch_market_data(symbol: str, period: str = "5d", interval: str = "1h"):
    """Obtiene datos de mercado (prioridad: Alpaca > yfinance)"""
    import numpy as np
    import pandas as pd
    from datetime import datetime, timedelta
    import time
    import requests
    
    print(f"🔍 Intentando obtener datos para {symbol}...")
    
    # ===== 1. INTENTAR CON ALPACA =====
    try:
        import sys
        import os
        sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
        
        try:
            from execution.alpaca_broker import alpaca_broker
            alpaca_available = True
        except:
            alpaca_available = False
            print("⚠️ Alpaca broker no disponible")
        
        if alpaca_available and alpaca_broker and hasattr(alpaca_broker, 'connected') and alpaca_broker.connected:
            print("📡 Usando Alpaca API...")
            
            end = datetime.now()
            if period == "5d":
                start = end - timedelta(days=5)
                timeframe = "1Hour"
            elif period == "1d":
                start = end - timedelta(days=1)
                timeframe = "5Min"
            else:
                start = end - timedelta(days=5)
                timeframe = "1Hour"
            
            url = f"https://data.alpaca.markets/v2/stocks/{symbol}/bars"
            headers = {
                'APCA-API-KEY-ID': alpaca_broker.api_key,
                'APCA-API-SECRET-KEY': alpaca_broker.secret_key
            }
            params = {
                'timeframe': timeframe,
                'start': start.strftime('%Y-%m-%dT%H:%M:%SZ'),
                'end': end.strftime('%Y-%m-%dT%H:%M:%SZ'),
                'limit': 1000
            }
            
            response = requests.get(url, headers=headers, params=params)
            
            if response.status_code == 200:
                data = response.json()
                bars = data.get('bars', [])
                
                if bars:
                    df = pd.DataFrame(bars)
                    df['timestamp'] = pd.to_datetime(df['t'])
                    df.set_index('timestamp', inplace=True)
                    df.rename(columns={
                        'o': 'Open', 'h': 'High', 'l': 'Low', 
                        'c': 'Close', 'v': 'Volume'
                    }, inplace=True)
                    
                    print(f"✅ {len(df)} velas obtenidas de Alpaca")
                    return df
            else:
                print(f"⚠️ Alpaca respondió con código {response.status_code}")
    
    except Exception as e:
        print(f"⚠️ Error con Alpaca: {e}")
    
    # ===== 2. FALLBACK: yfinance =====
    print("📡 Usando yfinance...")
    try:
        import yfinance as yf
        session = requests.Session()
        session.headers.update({
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
        })
        ticker = yf.Ticker(symbol, session=session)
        df = ticker.history(period=period, interval=interval)
        
        if not df.empty:
            print(f"✅ {len(df)} velas obtenidas de yfinance")
            return df
    except Exception as e:
        print(f"⚠️ yfinance falló: {e}")
    
    # ===== 3. DATOS SIMULADOS (solo si todo falla) =====
    print("⚠️ Usando datos simulados (MODO PRUEBAS)")
    dates = pd.date_range(end=datetime.now(), periods=100, freq='1h')
    df = pd.DataFrame(index=dates)
    np.random.seed(42)
    base_price = 45.0
    returns = np.random.randn(100) * 0.02
    price = base_price * np.exp(np.cumsum(returns))
    
    df['Close'] = price
    df['High'] = df['Close'] * (1 + np.abs(np.random.randn(100) * 0.01))
    df['Low'] = df['Close'] * (1 - np.abs(np.random.randn(100) * 0.01))
    df['Open'] = df['Close'].shift(1).fillna(df['Close'].iloc[0] * 0.99)
    df['Volume'] = np.random.randint(1000000, 10000000, 100)
    
    print("⚠️ DATOS SIMULADOS - SOLO PRUEBAS")
    return df


