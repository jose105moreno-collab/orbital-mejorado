class OrbitalVisualizer:
    """Visualizador profesional del modelo orbital"""
    
    def __init__(self, style: str = 'dark'):
        self.style = style
        self._setup_style()
    
    def _setup_style(self):
        if self.style == 'dark':
            plt.style.use('dark_background')
            self.colors = {
                'bg': '#1e1e1e', 'text': '#ffffff', 'grid': '#333333',
                'price': '#00ff88', 'vwap': '#ffaa00',
                'bb_upper': '#ff5555', 'bb_middle': '#888888', 'bb_lower': '#5555ff',
                'volume_up': '#00aa00', 'volume_down': '#aa0000',
                'signal_buy': '#00ff00', 'signal_sell': '#ff0000'
            }
        else:
            plt.style.use('default')
            self.colors = {
                'bg': '#ffffff', 'text': '#000000', 'grid': '#dddddd',
                'price': '#0066cc', 'vwap': '#ff9900',
                'bb_upper': '#ff3333', 'bb_middle': '#666666', 'bb_lower': '#3333ff',
                'volume_up': '#00cc00', 'volume_down': '#cc0000',
                'signal_buy': '#00aa00', 'signal_sell': '#aa0000'
            }
    
    def plot(self, df: pd.DataFrame, signals: List[Dict], title: str = "GODZILLA ORBITAL MODEL") -> plt.Figure:
        """Genera gráfica profesional compacta"""
        fig = plt.figure(figsize=(14, 8))
        gs = fig.add_gridspec(4, 1, height_ratios=[3, 1, 1, 1], hspace=0.02)
        
        ax1 = fig.add_subplot(gs[0])
        ax2 = fig.add_subplot(gs[1])
        ax3 = fig.add_subplot(gs[2])
        ax4 = fig.add_subplot(gs[3])
        
        # Gráfico 1: Precio y bandas
        if 'BB_upper' in df.columns:
            ax1.fill_between(df.index, df['BB_lower'], df['BB_upper'], 
                            alpha=0.1, color=self.colors['bb_middle'], zorder=1)
            ax1.plot(df.index, df['BB_upper'], color=self.colors['bb_upper'], 
                    linewidth=1, alpha=0.5, linestyle=':', zorder=2)
            ax1.plot(df.index, df['BB_middle'], color=self.colors['bb_middle'], 
                    linewidth=1, alpha=0.3, linestyle='-', zorder=2)
            ax1.plot(df.index, df['BB_lower'], color=self.colors['bb_lower'], 
                    linewidth=1, alpha=0.5, linestyle=':', zorder=2)
        
        if 'VWAP' in df.columns:
            ax1.plot(df.index, df['VWAP'], label='VWAP', color=self.colors['vwap'], 
                    linewidth=2.5, alpha=0.9, linestyle='-', zorder=3)
        
        ax1.plot(df.index, df['Close'], label='Precio', color=self.colors['price'], 
                linewidth=2, alpha=1, zorder=4)
        
        for signal in signals:
            if signal['signal'] > 0:
                ax1.scatter(signal['timestamp'], signal['price'], color=self.colors['signal_buy'], 
                          s=80, marker='^', zorder=5, edgecolor='white', linewidth=0.5)
                ax1.annotate(f"{signal['signal_type']}", (signal['timestamp'], signal['price']),
                           xytext=(5, 5), textcoords='offset points', color=self.colors['text'], 
                           fontsize=7, bbox=dict(boxstyle='round,pad=0.2', facecolor=self.colors['signal_buy'], alpha=0.7))
            elif signal['signal'] < 0:
                ax1.scatter(signal['timestamp'], signal['price'], color=self.colors['signal_sell'], 
                          s=80, marker='v', zorder=5, edgecolor='white', linewidth=0.5)
                ax1.annotate(f"{signal['signal_type']}", (signal['timestamp'], signal['price']),
                           xytext=(5, -10), textcoords='offset points', color=self.colors['text'], 
                           fontsize=7, bbox=dict(boxstyle='round,pad=0.2', facecolor=self.colors['signal_sell'], alpha=0.7))
        
        ax1.set_ylabel('Precio ($)', color=self.colors['text'], fontsize=9)
        ax1.legend(loc='upper left', framealpha=0.5, fontsize=7, ncol=3)
        ax1.grid(True, alpha=0.2, color=self.colors['grid'], linewidth=0.5)
        ax1.set_title(title, fontsize=12, fontweight='bold', color=self.colors['text'], pad=5)
        ax1.set_xticklabels([])
        ax1.tick_params(axis='x', length=0)
        
        # Gráfico 2: Volumen
        colors_vol = []
        for i in range(1, len(df)):
            if df['Close'].iloc[i] >= df['Close'].iloc[i-1]:
                colors_vol.append(self.colors['volume_up'])
            else:
                colors_vol.append(self.colors['volume_down'])
        colors_vol.insert(0, self.colors['volume_up'])
        
        ax2.bar(df.index, df['Volume'], color=colors_vol, alpha=0.7, width=0.8)
        ax2.set_ylabel('Volumen', color=self.colors['text'], fontsize=9)
        ax2.grid(True, alpha=0.2, color=self.colors['grid'], linewidth=0.5)
        
        if 'Volume' in df.columns:
            vol_ma = df['Volume'].rolling(20).mean()
            ax2.plot(df.index, vol_ma, color=self.colors['vwap'], 
                    linewidth=1, alpha=0.7, linestyle='--', label='Media 20')
        
        ax2.set_xticklabels([])
        ax2.tick_params(axis='x', length=0)
        
        # Gráfico 3: Energía orbital
        if 'Energy' in df.columns:
            ax3.plot(df.index, df['Energy'], color='#ff66ff', linewidth=1.5, alpha=0.9)
            
            # Líneas de threshold
            ax3.axhline(y=0.4, color=self.colors['bb_middle'], linestyle=':', alpha=0.5, linewidth=0.8, label='Low')
            ax3.axhline(y=0.9, color=self.colors['bb_upper'], linestyle=':', alpha=0.5, linewidth=0.8, label='High')
            ax3.axhline(y=1.5, color=self.colors['signal_sell'], linestyle=':', alpha=0.5, linewidth=0.8, label='Breakout')
            
            # Relleno por zonas
            ax3.fill_between(df.index, 0, 0.4, alpha=0.1, color='#00ff00')
            ax3.fill_between(df.index, 0.4, 0.9, alpha=0.1, color='#ffff00')
            ax3.fill_between(df.index, 0.9, 1.5, alpha=0.1, color='#ffaa00')
            ax3.fill_between(df.index, 1.5, df['Energy'].max(), alpha=0.15, color='#ff0000')
        
        ax3.set_ylabel('Energía', color=self.colors['text'], fontsize=9)
        ax3.set_ylim(bottom=0)
        ax3.grid(True, alpha=0.2, color=self.colors['grid'], linewidth=0.5)
        ax3.set_xticklabels([])
        ax3.tick_params(axis='x', length=0)
        
        # Gráfico 4: Posición en bandas
        if 'BB_position' in df.columns:
            ax4.plot(df.index, df['BB_position'], color='#00ffff', linewidth=1.5)
            ax4.fill_between(df.index, 0, 20, alpha=0.1, color=self.colors['bb_lower'])
            ax4.fill_between(df.index, 80, 100, alpha=0.1, color=self.colors['bb_upper'])
            ax4.axhline(y=50, color=self.colors['bb_middle'], linestyle='--', alpha=0.5, linewidth=0.8)
        
        ax4.set_ylabel('Pos BB (%)', color=self.colors['text'], fontsize=9)
        ax4.set_ylim(0, 100)
        ax4.set_xlabel('Fecha/Hora', color=self.colors['text'], fontsize=9)
        ax4.grid(True, alpha=0.2, color=self.colors['grid'], linewidth=0.5)
        
        # Formato de fechas
        ax4.xaxis.set_major_formatter(mdates.DateFormatter('%m/%d %H:%M'))
        ax4.tick_params(axis='x', rotation=45, colors=self.colors['text'], labelsize=8)
        
        for ax in [ax1, ax2, ax3]:
            ax.tick_params(axis='y', colors=self.colors['text'], labelsize=8)
        
        plt.tight_layout(pad=0.5)
        return fig


