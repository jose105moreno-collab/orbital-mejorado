# CLASE PRINCIPAL DRAGON SELLER
# ============================================
class DragonSeller:
    def __init__(self):
        self.market = MarketData()
        self.indicators = Indicators()
        self.risk = RiskManager()
        self.last_alerts = {}  # symbol -> timestamp of last alert
        self.alert_cooldown = 3600  # 1 hora entre alertas del mismo símbolo

    def analyze_symbol(self, symbol):
        """Analiza múltiples timeframes y devuelve resultado de venta"""
        confirmations = 0
        total_tf = len(TIMEFRAMES)
        tf_results = {}

        for tf in TIMEFRAMES:
            df = self.market.get_data(symbol, days=2, timeframe=tf)
            if df is None or len(df) < 20:
                continue

            # Calcular VWAP
            df['VWAP'] = self.indicators.vwap_orbital(df)
            price = df['Close'].iloc[-1]
            vwap = df['VWAP'].iloc[-1]
            deviation = ((price - vwap) / vwap) * 100

            # Calcular Bollinger y ATR para el stop dinámico
            bb_upper, bb_mid, bb_lower = self.indicators.bollinger_bands(df)
            atr = self.indicators.atr(df).iloc[-1]

            tf_results[tf] = {
                'price': price,
                'vwap': vwap,
                'deviation': deviation,
                'bb_lower': bb_lower.iloc[-1],
                'atr': atr,
                'volume_avg': df['Volume'].tail(20).mean()
            }

            if deviation > SELL_THRESHOLD:
                confirmations += 1

        return confirmations, total_tf, tf_results

    def generate_alert(self, symbol, confirmations, total_tf, tf_results):
        """Crea mensaje de alerta con nivel de confianza"""
        if confirmations == 0:
            return None, None

        nivel = "BAJA"
        emoji = "🟡"
        if confirmations >= total_tf:
            nivel = "ALTA"
            emoji = "🔴"
        elif confirmations >= total_tf // 2:
            nivel = "MEDIA"
            emoji = "🟠"

        # Tomar datos del timeframe principal (1h)
        principal = tf_results.get('1h', {})
        price = principal.get('price', 0)
        vwap = principal.get('vwap', 0)
        deviation = principal.get('deviation', 0)

        msg = f"""{emoji} *SEÑAL DE VENTA {symbol}*

📊 *Confirmación:* {confirmations}/{total_tf} timeframes
🎯 *Nivel:* {nivel}

💰 Precio: ${price:.2f}
📈 VWAP: ${vwap:.2f}
📊 Desviación: +{deviation:.2f}%

⏱️ Timeframes:
"""
        for tf, data in tf_results.items():
            emoji_tf = "🔴" if data['deviation'] > SELL_THRESHOLD else "⚪"
            msg += f"  {emoji_tf} {tf}: {data['deviation']:+.2f}%\n"

        # Añadir info de riesgo si hay posición activa
        pos = self.risk.active_positions.get(symbol)
        if pos:
            msg += f"\n📌 Posición activa: {pos['quantity']} @ ${pos['entry_price']:.2f}\n"
            msg += f"🛑 Stop Loss: ${pos['stop_loss']:.2f}\n"

        msg += f"\n🐉 GODZILLA ORBITAL v5\n⏰ {datetime.now().strftime('%H:%M:%S')}"
        return msg, nivel

    def manage_position(self, symbol, tf_results):
        """Actualiza stop loss y liquidez, cierra si corresponde"""
        pos = self.risk.active_positions.get(symbol)
        if not pos:
            return None

        # Tomar datos del timeframe 1h para el símbolo
        data = tf_results.get('1h', {})
        if not data:
            return None

        current_price = data['price']
        atr = data['atr']
        bb_lower = data['bb_lower']

        # Actualizar ATR en la posición
        pos['atr'] = atr

        # Trailing stop
        self.risk.update_trailing_stop(symbol, current_price)

        # Verificar si debe cerrar por stop loss
        if self.risk.should_close(symbol, current_price):
            closed = self.risk.close_position(symbol, current_price, reason='stop_loss')
            if closed:
                self._send_position_close_alert(closed)
            return closed

        # Revisar rebote desde la banda inferior
        self.risk.check_rebound_stop(symbol, current_price, bb_lower)

        return None

    def _send_position_close_alert(self, closed):
        msg = f"""🛑 *POSICIÓN CERRADA* {closed['symbol']}

📉 Precio salida: ${closed['exit']:.2f}
💰 P&L: ${closed['pnl']:+.2f}
💡 Razón: {closed['reason']}

🐉 GODZILLA ORBITAL v5
⏰ {datetime.now().strftime('%H:%M:%S')}"""
        send_telegram(msg)

    def execute_sell_signal(self, symbol, confirmations, total_tf, tf_results):
        """Ejecuta la lógica de venta (cierra posición existente o abre nueva en corto)"""
        # Si ya hay posición, la cerramos (venta)
        if symbol in self.risk.active_positions:
            closed = self.risk.close_position(symbol, tf_results['1h']['price'], reason='sell_signal')
            if closed:
                self._send_position_close_alert(closed)
            return True

        # Aquí se podría abrir una posición en corto (short) si el broker lo permite.
        # Por ahora solo cerramos posiciones largas.
        return False

    def run(self, symbol, interval=5):
        print(f"\n🐉 INICIANDO DRAGON SELLER para {symbol}")
        send_telegram(f"🐉 *DRAGON SELLER* inició monitoreo de {symbol}")

        while True:
            try:
                confirmations, total_tf, tf_results = self.analyze_symbol(symbol)

                # Gestionar posición existente (stop loss, trailing)
                closed = self.manage_position(symbol, tf_results)
                if closed:
                    print(f"🔚 Posición cerrada en {symbol} con P&L ${closed['pnl']:+.2f}")

                # Evaluar señal de venta
                if confirmations > 0:
                    alert, nivel = self.generate_alert(symbol, confirmations, total_tf, tf_results)
                    if alert:
                        # Evitar spam: solo si ha pasado el cooldown
                        last_alert = self.last_alerts.get(symbol, datetime.min)
                        if (datetime.now() - last_alert).total_seconds() > self.alert_cooldown:
                            print("\n" + "🔴"*50)
                            print(alert)
                            print("🔴"*50)
                            send_telegram(alert)
                            self.last_alerts[symbol] = datetime.now()

                            # Ejecutar venta si la señal es ALTA y tenemos posición
                            if nivel == "ALTA" and symbol in self.risk.active_positions:
                                self.execute_sell_signal(symbol, confirmations, total_tf, tf_results)
                else:
                    print(f"\n⚪ {datetime.now().strftime('%H:%M:%S')} - Sin señales de venta")

                # Esperar
                time.sleep(interval * 60)

            except KeyboardInterrupt:
                print("\n🛑 Monitoreo detenido")
                send_telegram("🛑 *DRAGON SELLER* detuvo el monitoreo")
                break
            except Exception as e:
                print(f"❌ Error: {e}")
                time.sleep(60)

    def demo_trade(self, symbol):
        """Simula una compra manual para probar gestión de posición"""
        # Obtener precio actual
        df = self.market.get_data(symbol, days=1, timeframe='1h')
        if df is None:
            print("No se pudo obtener precio")
            return
        price = df['Close'].iloc[-1]

        # Calcular volumen promedio y ATR
        volume_avg = df['Volume'].tail(20).mean()
        atr = self.indicators.atr(df).iloc[-1]

        # Calcular cantidad
        quantity = self.risk.calculate_position_size(symbol, price, volume_avg)
        if quantity == 0:
            print("No se puede abrir posición por falta de liquidez")
            return

        # Abrir posición
        if self.risk.open_position(symbol, price, quantity, atr):
            print(f"✅ Posición abierta: {symbol} {quantity} @ ${price:.2f}")
            send_telegram(f"✅ *POSICIÓN ABIERTA* {symbol}\nCantidad: {quantity}\nPrecio: ${price:.2f}")
        else:
            print("Ya hay una posición abierta")

