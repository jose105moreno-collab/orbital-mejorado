# CLASE PARA OBTENER DATOS DE MERCADO
# ============================================
class MarketData:
    def __init__(self):
        self.alpaca_key = ALPACA_API_KEY
        self.alpaca_secret = ALPACA_SECRET_KEY

    def get_stock_data(self, symbol, days=5, timeframe='1h'):
        """Obtiene velas horarias de Alpaca"""
        if not self.alpaca_key:
            return None

        tf_map = {'15m': '15Min', '1h': '1Hour', '4h': '1Hour'}
        alpaca_tf = tf_map.get(timeframe, '1Hour')
        end = datetime.now()
        start = end - timedelta(days=days)

        url = f"https://data.alpaca.markets/v2/stocks/{symbol}/bars"
        headers = {
            'APCA-API-KEY-ID': self.alpaca_key,
            'APCA-API-SECRET-KEY': self.alpaca_secret
        }
        params = {
            'timeframe': alpaca_tf,
            'start': start.strftime('%Y-%m-%dT%H:%M:%SZ'),
            'end': end.strftime('%Y-%m-%dT%H:%M:%SZ'),
            'limit': 1000
        }
        try:
            r = requests.get(url, headers=headers, params=params, timeout=10)
            if r.status_code == 200:
                data = r.json()
                bars = data.get('bars', [])
                if bars:
                    df = pd.DataFrame(bars)
                    df['timestamp'] = pd.to_datetime(df['t'])
                    df.set_index('timestamp', inplace=True)
                    df.rename(columns={
                        'o': 'Open', 'h': 'High', 'l': 'Low',
                        'c': 'Close', 'v': 'Volume'
                    }, inplace=True)
                    return df
        except Exception:
            pass
        return None

    def get_crypto_data(self, symbol, days=5, timeframe='1h'):
        """Obtiene velas de Binance"""
        symbol_map = {
            'BTC-USD': 'BTCUSDT', 'ETH-USD': 'ETHUSDT', 'SOL-USD': 'SOLUSDT',
            'ADA-USD': 'ADAUSDT', 'DOGE-USD': 'DOGEUSDT', 'AVAX-USD': 'AVAXUSDT'
        }
        binance_symbol = symbol_map.get(symbol)
        if not binance_symbol:
            return None

        interval_map = {'15m': '15m', '1h': '1h', '4h': '4h'}
        interval = interval_map.get(timeframe, '1h')

        end_time = int(datetime.now().timestamp() * 1000)
        start_time = end_time - days * 24 * 60 * 60 * 1000

        url = "https://api.binance.com/api/v3/klines"
        params = {
            'symbol': binance_symbol,
            'interval': interval,
            'startTime': start_time,
            'endTime': end_time,
            'limit': 500
        }
        try:
            r = requests.get(url, params=params, timeout=10)
            if r.status_code == 200:
                data = r.json()
                df = pd.DataFrame(data, columns=[
                    'timestamp', 'open', 'high', 'low', 'close', 'volume',
                    'close_time', 'qa_vol', 'trades', 'taker_base', 'taker_quote', 'ignore'
                ])
                df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')
                df.set_index('timestamp', inplace=True)
                df = df[['open', 'high', 'low', 'close', 'volume']].astype(float)
                df.rename(columns={
                    'open': 'Open', 'high': 'High', 'low': 'Low',
                    'close': 'Close', 'volume': 'Volume'
                }, inplace=True)
                return df
        except Exception:
            pass
        return None

    def get_data(self, symbol, days=5, timeframe='1h'):
        if '-USD' in symbol:
            return self.get_crypto_data(symbol, days, timeframe)
        else:
            return self.get_stock_data(symbol, days, timeframe)

# ============================================
# CLASE DE INDICADORES (VWAP, BOLLINGER, ATR)
# ============================================
class Indicators:
    @staticmethod
    def vwap_orbital(df, lambda_decay=0.3, alpha_smooth=0.1):
        """VWAP con peso temporal y suavizado (fórmula ganadora)"""
        df = df.copy()
        df['typical'] = (df['High'] + df['Low'] + df['Close']) / 3
        n = len(df)
        weights = np.exp(-lambda_decay * np.arange(n)[::-1])
        df['time_weight'] = weights / weights.mean()
        df['weighted_pv'] = df['typical'] * df['Volume'] * df['time_weight']
        df['weighted_vol'] = df['Volume'] * df['time_weight']

        vwap = []
        cum_pv = df['weighted_pv'].iloc[0]
        cum_vol = df['weighted_vol'].iloc[0]
        vwap.append(cum_pv / cum_vol)

        for i in range(1, len(df)):
            cum_pv = alpha_smooth * cum_pv + (1 - alpha_smooth) * df['weighted_pv'].iloc[i]
            cum_vol = alpha_smooth * cum_vol + (1 - alpha_smooth) * df['weighted_vol'].iloc[i]
            vwap.append(cum_pv / cum_vol)

        return pd.Series(vwap, index=df.index)

    @staticmethod
    def bollinger_bands(df, period=20, num_std=2.0):
        """Bollinger Bands estándar"""
        df = df.copy()
        df['sma'] = df['Close'].rolling(period).mean()
        df['std'] = df['Close'].rolling(period).std()
        df['bb_upper'] = df['sma'] + num_std * df['std']
        df['bb_lower'] = df['sma'] - num_std * df['std']
        return df['bb_upper'], df['sma'], df['bb_lower']

    @staticmethod
    def atr(df, period=14):
        """Average True Range"""
        df = df.copy()
        high_low = df['High'] - df['Low']
        high_close = abs(df['High'] - df['Close'].shift())
        low_close = abs(df['Low'] - df['Close'].shift())
        tr = pd.concat([high_low, high_close, low_close], axis=1).max(axis=1)
        atr = tr.rolling(period).mean()
        return atr

# ============================================
# CLASE DE GESTIÓN DE RIESGOS
# ============================================
class RiskManager:
    def __init__(self, capital=VIRTUAL_CAPITAL):
        self.capital = capital
        self.active_positions = {}  # symbol -> {'entry_price', 'quantity', 'stop_loss', 'trailing_trigger'}

    def calculate_position_size(self, symbol, price, volume_avg, timeframe_volume=None):
        """Calcula cantidad basada en liquidez y riesgo"""
        # Volumen promedio diario en acciones (o en USDT para crypto)
        if volume_avg is None or volume_avg <= 0:
            return 0

        # Máximo valor a invertir según porcentaje de capital
        max_value = self.capital * MAX_POSITION_PCT

        # Ajustar por liquidez: no más del 0.5% del volumen promedio diario
        max_shares_by_liquidity = volume_avg * 0.005  # 0.5% del volumen diario
        max_value_by_liquidity = max_shares_by_liquidity * price

        # Tomar el menor de los dos
        max_value = min(max_value, max_value_by_liquidity)

        if max_value <= 0:
            return 0

        quantity = max_value / price
        # Redondear a entero para acciones
        if symbol and '-' not in symbol:
            quantity = int(quantity)
        else:
            quantity = round(quantity, 4)  # crypto
        return quantity

    def update_trailing_stop(self, symbol, current_price):
        """Actualiza stop loss dinámico basado en trailing ATR"""
        pos = self.active_positions.get(symbol)
        if not pos:
            return None

        # Necesitamos el ATR actual del símbolo (se pasa desde afuera)
        atr_val = pos.get('atr', 0)
        if atr_val <= 0:
            return pos['stop_loss']

        # Trailing stop: el stop se mueve hacia arriba a medida que sube el precio
        new_stop = current_price - TRAILING_STOP_ATR_MULT * atr_val
        if new_stop > pos['stop_loss']:
            pos['stop_loss'] = new_stop
        return pos['stop_loss']

    def check_rebound_stop(self, symbol, current_price, bb_lower):
        """Si el precio toca la banda inferior y rebota, ajustar stop loss"""
        pos = self.active_positions.get(symbol)
        if not pos:
            return False

        # Si el precio está cerca de la banda inferior (dentro del rebote %) y ha estado bajando
        if current_price <= bb_lower * (1 + BOLLINGER_REBOUND_PCT / 100):
            # Movemos el stop loss al punto de entrada (break even) o un poco más
            pos['stop_loss'] = pos['entry_price']
            return True
        return False

    def open_position(self, symbol, price, quantity, atr):
        """Abre una nueva posición"""
        if symbol in self.active_positions:
            print(f"⚠️ Ya hay una posición abierta para {symbol}")
            return False

        self.active_positions[symbol] = {
            'entry_price': price,
            'quantity': quantity,
            'stop_loss': price - TRAILING_STOP_ATR_MULT * atr,
            'trailing_trigger': price,
            'atr': atr,
            'timestamp': datetime.now()
        }
        return True

    def close_position(self, symbol, current_price, reason='manual'):
        """Cierra una posición y registra P&L"""
        pos = self.active_positions.pop(symbol, None)
        if not pos:
            return None

        pnl = (current_price - pos['entry_price']) * pos['quantity']
        return {
            'symbol': symbol,
            'entry': pos['entry_price'],
            'exit': current_price,
            'quantity': pos['quantity'],
            'pnl': pnl,
            'reason': reason
        }

    def should_close(self, symbol, current_price):
        """Verifica si se debe cerrar por stop loss"""
        pos = self.active_positions.get(symbol)
        if not pos:
            return False
        return current_price <= pos['stop_loss']

