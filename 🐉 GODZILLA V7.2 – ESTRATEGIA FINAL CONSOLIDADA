    df['Volume'] = np.random.randint(1e6, 5e6, 500)
    return df

# ============================================
# 2. INDICADORES (CORE)
# ============================================
def atr(df, period=14):
    high_low = df['High'] - df['Low']
    high_close = abs(df['High'] - df['Close'].shift())
    low_close = abs(df['Low'] - df['Close'].shift())
    tr = pd.concat([high_low, high_close, low_close], axis=1).max(axis=1)
    return tr.rolling(period).mean()

def connors_rsi(df, rsi_period=3, streak_period=2, roc_period=100):
    """Connors RSI – el que usan en Investing.com."""
    close = df['Close']

    # 1. RSI de 3 periodos
    delta = close.diff()
    gain = delta.clip(lower=0)
    loss = (-delta).clip(lower=0)
    avg_gain = gain.ewm(alpha=1/rsi_period, adjust=False).mean()
    avg_loss = loss.ewm(alpha=1/rsi_period, adjust=False).mean()
    rs = avg_gain / avg_loss
    rsi_3 = 100 - (100 / (1 + rs))

    # 2. RSI del streak (racha)
    direction = np.sign(close.diff())
    streak = []
    streak_val = 0
    for i in range(len(df)):
        if i == 0:
            streak_val = 0
        else:
            if direction.iloc[i] == direction.iloc[i-1]:
                streak_val += direction.iloc[i]
            else:
                streak_val = direction.iloc[i]
        streak.append(streak_val)
    df['streak'] = streak
    delta_s = df['streak'].diff()
    gain_s = delta_s.clip(lower=0)
    loss_s = (-delta_s).clip(lower=0)
    avg_gain_s = gain_s.ewm(alpha=1/streak_period, adjust=False).mean()
    avg_loss_s = loss_s.ewm(alpha=1/streak_period, adjust=False).mean()
    rs_s = avg_gain_s / avg_loss_s
    rsi_streak = 100 - (100 / (1 + rs_s))

    # 3. Percent Rank del ROC
    roc = close.pct_change() * 100
    def percent_rank(arr):
        current = arr[-1]
        return (arr < current).sum() / len(arr) * 100
    percent_rank_series = roc.rolling(roc_period).apply(percent_rank, raw=True)
    percent_rank_series = percent_rank_series.fillna(50)

    crsi = (rsi_3 + rsi_streak + percent_rank_series) / 3
    return crsi.fillna(50)

def compute_indicators(df):
    """Añade todas las columnas de indicadores necesarias."""
    df = df.copy()
    # Bollinger Bands (20,2)
    df['sma'] = df['Close'].rolling(20).mean()
    df['std'] = df['Close'].rolling(20).std()
    df['bb_upper'] = df['sma'] + 2 * df['std']
    df['bb_lower'] = df['sma'] - 2 * df['std']
    # ATR
    df['ATR'] = atr(df)
    # Connors RSI
    df['CRSI'] = connors_rsi(df)
    # Volatilidad normalizada
    df['vol_regime'] = df['ATR'] / df['Close']
    return df

