# 3. ESTRATEGIA V7.2 (CON PARÁMETROS AJUSTABLES)
# ============================================
class V7_2Strategy:
    def __init__(self, params):
        self.params = params

    def generate_signals(self, df):
        """
        Genera columnas 'entry' y 'exit_crsi' basado en parámetros.
        """
        df = df.copy()
        # CRSI dinámico (percentil móvil)
        crsi_thresh = df['CRSI'].rolling(100, min_periods=50).quantile(self.params['crsi_percentile']).fillna(50)

        # Filtros de mercado
        df['market_ok'] = (
            (df['vol_regime'] < self.params['max_volatility']) &
            (df['ATR'] >= self.params['min_atr'])
        )
        # Evitar caída fuerte en últimos 3 días (opcional, pero mejora robustez)
        df['no_steep_drop'] = (df['Close'] / df['Close'].shift(3) - 1) > -0.06

        # Entrada
        entry_cond = (
            (df['Close'] < df['bb_lower']) &                              # extremo
            (df['CRSI'] < crsi_thresh) &                                 # CRSI bajo
            (df['Close'] < df['Close'].shift(1)) &                        # caída confirmada
            df['market_ok'] &
            df['no_steep_drop']
        )
        df['entry'] = entry_cond

        # Salida por CRSI (sobrecompra)
        df['exit_crsi'] = df['CRSI'] > self.params['crsi_exit']

        return df

# ============================================
# 4. MOTOR DE EJECUCIÓN (CON TODAS LAS MEJORAS)
# ============================================
class ExecutionEngine:
    def __init__(self, capital_inicial=100000, params=None):
        self.capital_inicial = capital_inicial
        self.params = params or {}

    def run(self, df, strategy):
        """
        Ejecuta la estrategia sobre el DataFrame.
        Retorna equity_curve (lista) y trades (lista de dicts).
        """
        df = strategy.generate_signals(df)

        capital = self.capital_inicial
        positions = []          # lista de posiciones abiertas
        equity = [capital]
        trades = []

        for i in range(50, len(df)):
            price = df['Close'].iloc[i]
            atr = df['ATR'].iloc[i]
            crsi = df['CRSI'].iloc[i]
            entry_signal = df['entry'].iloc[i]

            # ---- ENTRY (PYRAMIDING CONTROLADO) ----
            if entry_signal and len(positions) < self.params.get('max_entries', 2):
                # Calcular exposición actual
                current_exposure = sum(p['entry_price'] * p['size'] for p in positions) / equity[-1]
                if current_exposure < self.params.get('max_exposure', 0.30):
                    # Solo añadir si el precio es menor que la última entrada (promediar hacia abajo)
                    if not positions or price < positions[-1]['entry_price'] * 0.995:
                        entry_price = price * (1 + self.params.get('slippage', 0.001))
                        # Tamaño basado en porcentaje del equity actual
                        size = (equity[-1] * self.params.get('position_size_pct', 0.10)) / entry_price
                        cost = entry_price * size * self.params.get('commission', 0.001)
                        capital -= (entry_price * size + cost)

                        positions.append({
                            'entry_price': entry_price,
                            'size': size,
                            'atr_entry': atr,
                            'highest_price': entry_price
                        })

                        trades.append({
                            'fecha': df.index[i],
                            'tipo': 'COMPRA',
                            'precio': entry_price,
                            'cantidad': size,
                            'capital_restante': capital,
                            'crsi': crsi
                        })

            # ---- EXIT LOGIC (PARA CADA POSICIÓN) ----
            new_positions = []
            for pos in positions:
                entry = pos['entry_price']
                size = pos['size']
                atr_entry = pos['atr_entry']
                if price > pos['highest_price']:
                    pos['highest_price'] = price

                # Take profit y stop loss basados en ATR de entrada
                tp = entry + self.params.get('tp_atr', 0.9) * atr_entry
                sl = entry - self.params.get('sl_atr', 0.8) * atr_entry

                # Trailing stop: activar después de 1 ATR de ganancia
                profit_atr = (price - entry) / atr_entry
                trailing_sl = None
                if profit_atr > 1:
                    trailing_sl = pos['highest_price'] - 0.5 * atr_entry

                exit_flag = False
                exit_reason = ''

                if price >= tp:
                    exit_flag = True
                    exit_reason = 'take_profit'
                elif price <= sl:
                    exit_flag = True
                    exit_reason = 'stop_loss'
                elif trailing_sl is not None and price <= trailing_sl:
                    exit_flag = True
                    exit_reason = 'trailing'
                elif crsi > self.params.get('crsi_exit', 70):
                    exit_flag = True
                    exit_reason = 'crsi_exit'

                if exit_flag:
                    exit_price = price * (1 - self.params.get('slippage', 0.001))
                    cost = exit_price * size * self.params.get('commission', 0.001)
                    pnl = (exit_price - entry) * size - cost
                    capital += exit_price * size - cost
                    trades.append({
                        'fecha': df.index[i],
                        'tipo': 'VENTA',
                        'precio': exit_price,
                        'cantidad': size,
                        'pnl': pnl,
                        'razon': exit_reason,
                        'crsi': crsi
                    })
                else:
                    new_positions.append(pos)

            positions = new_positions

            # Equity total (capital + valor de posiciones)
            pos_value = sum(p['size'] * price for p in positions)
            equity.append(capital + pos_value)

        return equity, trades

# ============================================
# 5. MÉTRICAS DE RENDIMIENTO
# ============================================
def compute_metrics(equity, trades, capital_inicial):
    eq = pd.Series(equity)
    returns = eq.pct_change().dropna()
    sharpe = returns.mean() / returns.std() * np.sqrt(252) if returns.std() > 0 else 0
    total_return = eq.iloc[-1] / eq.iloc[0] - 1

    peak = eq.expanding().max()
    drawdown = (peak - eq) / peak
    max_dd = drawdown.min()
    max_dd_value = (peak - eq).max()

    # Análisis de trades
    trades_df = pd.DataFrame(trades)
    if not trades_df.empty:
        exits = trades_df[trades_df['tipo'] == 'VENTA']
        if not exits.empty:
            pnls = exits['pnl'].values
            ganadoras = (pnls > 0).sum()
            num_trades = len(pnls)
            win_rate = ganadoras / num_trades * 100 if num_trades > 0 else 0
            avg_win = pnls[pnls > 0].mean() if ganadoras > 0 else 0
            avg_loss = pnls[pnls < 0].mean() if (num_trades - ganadoras) > 0 else 0
            profit_factor = pnls[pnls > 0].sum() / abs(pnls[pnls < 0].sum()) if (pnls[pnls < 0].sum() != 0) else np.inf
            expectancy = np.mean(pnls) if len(pnls) > 0 else 0
        else:
            win_rate = 0; avg_win = 0; avg_loss = 0; profit_factor = 0; expectancy = 0; num_trades = 0
    else:
        win_rate = 0; avg_win = 0; avg_loss = 0; profit_factor = 0; expectancy = 0; num_trades = 0

    return {
        'capital_final': eq.iloc[-1],
        'total_return': total_return,
        'sharpe': sharpe,
        'max_drawdown': max_dd,
        'max_drawdown_value': max_dd_value,
        'num_trades': num_trades,
        'win_rate': win_rate,
        'profit_factor': profit_factor,
        'expectancy': expectancy,
        'avg_win': avg_win,
        'avg_loss': avg_loss
    }

# ============================================
# 6. GRID SEARCH (SÓLO TRES PARÁMETROS)
# ============================================
def grid_search(df, tp_range, sl_range, crsi_range, base_params):
    """
    Realiza búsqueda en rejilla sobre tp_atr, sl_atr y crsi_percentile.
    Retorna DataFrame con resultados.
    """
    results = []
    for tp in tp_range:
        for sl in sl_range:
            for crsi_p in crsi_range:
                params = base_params.copy()
                params['tp_atr'] = tp
                params['sl_atr'] = sl
                params['crsi_percentile'] = crsi_p

                strategy = V7_2Strategy(params)
                engine = ExecutionEngine(capital_inicial=100000, params=params)
                equity, trades = engine.run(df, strategy)
                metrics = compute_metrics(equity, trades, 100000)

                results.append({
                    'tp': tp,
                    'sl': sl,
                    'crsi': crsi_p,
                    'sharpe': metrics['sharpe'],
                    'return': metrics['total_return'],
                    'max_dd': metrics['max_drawdown'],
                    'profit_factor': metrics['profit_factor'],
                    'num_trades': metrics['num_trades']
                })
    return pd.DataFrame(results)

# ============================================
# 7. VISUALIZACIÓN (HEATMAP)
# ============================================
def plot_heatmap(df_results, metric='sharpe'):
    """Genera heatmap de la métrica seleccionada."""
    pivot = df_results.pivot_table(values=metric, index='tp', columns='sl')
    plt.figure(figsize=(8,6))
    sns.heatmap(pivot, annot=True, fmt='.2f', cmap='viridis')
    plt.title(f'Heatmap – {metric.upper()}')
    plt.tight_layout()
    plt.show()

