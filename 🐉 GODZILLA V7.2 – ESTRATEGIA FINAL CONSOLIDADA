# 8. FUNCIÓN PRINCIPAL (EJECUCIÓN)
# ============================================
def main(symbol="TQQQ", capital=100000, optimize=False):
    """
    Ejecuta el backtest completo. Si optimize=True, realiza grid search.
    """
    print("="*70)
    print("🐉 GODZILLA V7.2 – ESTRATEGIA FINAL CONSOLIDADA")
    print("="*70)
    print(f"Símbolo: {symbol}")
    print(f"Capital inicial: ${capital:,.2f}")

    # Cargar datos
    df = get_daily_data(symbol)
    if df.empty:
        print("❌ No se pudieron obtener datos.")
        return
    df = compute_indicators(df)

    # Parámetros base recomendados
    base_params = {
        'crsi_percentile': 0.20,
        'max_entries': 2,
        'position_size_pct': 0.10,
        'max_exposure': 0.30,
        'max_volatility': 0.05,
        'min_atr': 0.005,
        'commission': 0.001,
        'slippage': 0.001,
        'crsi_exit': 70,
        'tp_atr': 0.9,
        'sl_atr': 0.8,
        'use_lower_band': True,
        'require_down_move': True,
        'add_only_lower': True
    }

    if optimize:
        print("\n🔍 Ejecutando Grid Search sobre tp_atr, sl_atr, crsi_percentile...")
        tp_range = np.arange(0.7, 1.1, 0.1)
        sl_range = np.arange(0.7, 1.1, 0.1)
        crsi_range = [0.15, 0.20, 0.25, 0.30]
        results = grid_search(df, tp_range, sl_range, crsi_range, base_params)
        print("\n📊 TOP 10 CONFIGURACIONES (por Sharpe)")
        print(results.sort_values('sharpe', ascending=False).head(10))

        plot_heatmap(results, metric='sharpe')
        return results
    else:
        # Usar configuración base recomendada
        strategy = V7_2Strategy(base_params)
        engine = ExecutionEngine(capital_inicial=capital, params=base_params)
        equity, trades = engine.run(df, strategy)
        metrics = compute_metrics(equity, trades, capital)

        print("\n📈 RESULTADOS BACKTEST (configuración base)")
        print("="*60)
        print(f"Capital final: ${metrics['capital_final']:,.2f}")
        print(f"Rentabilidad total: {metrics['total_return']:.2%}")
        print(f"Sharpe Ratio (anualizado): {metrics['sharpe']:.2f}")
        print(f"Max Drawdown: {metrics['max_drawdown']:.2%} (${metrics['max_drawdown_value']:,.2f})")
        print(f"Número de trades: {metrics['num_trades']}")
        if metrics['num_trades'] > 0:
            print(f"Win Rate: {metrics['win_rate']:.1f}%")
            print(f"Profit Factor: {metrics['profit_factor']:.2f}")
            print(f"Expectancy por trade: ${metrics['expectancy']:.2f}")
            if metrics['avg_loss'] != 0:
                print(f"Risk/Reward: {abs(metrics['avg_win']/metrics['avg_loss']):.2f}")

        # Gráfica equity curve
        fig, ax = plt.subplots(figsize=(12, 6))
        ax.plot(df.index[:len(equity)], equity, label='Equity Curve', color='blue', linewidth=1.5)
        ax.set_title(f'Equity Curve – {symbol}')
        ax.set_xlabel('Fecha')
        ax.set_ylabel('Capital ($)')
        ax.grid(True, alpha=0.3)
        ax.legend()
        plt.tight_layout()
        plt.show()

        # Guardar trades
        if trades:
            trades_df = pd.DataFrame(trades)
            trades_df.to_csv(f"{symbol}_trades_v7_2.csv", index=False)
            print(f"✅ Trades guardados en {symbol}_trades_v7_2.csv")
        return equity, trades

